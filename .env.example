# ─────────────────────────────────────────────────────────────────
# Скопируйте этот файл в .env и заполните свои значения:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# JWT (обязательно поменяйте на что-то случайное!)
JWT_SECRET=super_secret_change_me_please

# Cloudinary (для загрузки изображений)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (для отправки писем)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=3D Print Lab <your_email@gmail.com>

# URL фронтенда (для CORS)
CLIENT_URL=http://localhost

# URL API для клиента (если бэкенд на другом хосте)
VITE_API_URL=http://localhost:5000/api
